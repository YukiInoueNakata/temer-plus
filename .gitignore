old_file/**/*.xlsm
old_file/**/*.pptx
old_file/**/*.pdf
old_file/2024TEA学会シンポ/

# Node / Web開発
node_modules/
webApp/node_modules/
webApp/dist/
webApp/*.tsbuildinfo
*.log

# OS / IDE
.DS_Store
.vscode/
.idea/

# CSV データ（個人情報を含む可能性）
中田_2024_TEMシンポ*.csv

# Markdown ドキュメント（現在は非公開）
*.md
**/*.md
# LICENSE はテキストファイルなので影響なし

# docs/（調査資料・文献PDF・画像はローカル保持）
docs/*
# ただしユーザ向けマニュアル/チュートリアルは tracked
!docs/manual/
!docs/manual/**

# Web アプリからの出力ファイル（ルート直下 / webApp 直下）
/*.png
/*.svg
/*.tem
webApp/*.png
webApp/*.svg
webApp/*.tem
LICENSE
